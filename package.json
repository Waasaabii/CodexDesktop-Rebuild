{
  "name": "codex-tauri-refactor",
  "version": "0.1.0",
  "private": true,
  "description": "Tauri refactor shell for Codex desktop with UI parity and performance-focused backend",
  "scripts": {
    "dev:web": "vite --config frontend/vite.config.js --host 127.0.0.1 --port 1420",
    "build:web": "vite build --config frontend/vite.config.js",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.12",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^7.1.7"
  }
}
